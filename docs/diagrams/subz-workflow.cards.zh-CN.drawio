  <diagram id="subz-workflow-cards-zh" name="SubZ 流程图 - 彩色卡片版 (中文)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="100" value="预检查阶段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1;dashed=1;dashPattern=6 4;fontStyle=1;fontColor=#334155;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;arcSize=10;" vertex="1" parent="1"><mxGeometry x="290" y="34" width="980" height="290" as="geometry"/></mxCell>
        <mxCell id="101" value="执行流水线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1;dashed=1;dashPattern=6 4;fontStyle=1;fontColor=#334155;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;arcSize=10;" vertex="1" parent="1"><mxGeometry x="290" y="350" width="980" height="500" as="geometry"/></mxCell>
        <mxCell id="102" value="输出结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1;dashed=1;dashPattern=6 4;fontStyle=1;fontColor=#334155;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;arcSize=10;" vertex="1" parent="1"><mxGeometry x="290" y="870" width="980" height="170" as="geometry"/></mxCell>
        <mxCell id="2" value="输入&#xa;视频文件" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="640" y="88" width="280" height="78" as="geometry"/></mxCell>
        <mxCell id="3" value="跳过检查&#xa;是否已有目标语言字幕？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;strokeWidth=2;fontSize=14;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="620" y="198" width="320" height="122" as="geometry"/></mxCell>
        <mxCell id="9" value="跳过&#xa;已存在目标字幕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;strokeWidth=2;fontSize=13;fontColor=#0f172a;arcSize=12;" vertex="1" parent="1"><mxGeometry x="1000" y="220" width="250" height="86" as="geometry"/></mxCell>
        <mxCell id="4" value="[1] 源字幕检测&#xa;优先外部字幕，其次封装内文本字幕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;strokeWidth=2;fontSize=13;fontColor=#0f172a;align=left;spacingLeft=12;spacingTop=8;arcSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="410" width="560" height="102" as="geometry"/></mxCell>
        <mxCell id="5" value="[2] 回退策略&#xa;若首选语言缺失，则使用任意可用字幕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;strokeWidth=2;fontSize=13;fontColor=#0f172a;align=left;spacingLeft=12;spacingTop=8;arcSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="540" width="560" height="102" as="geometry"/></mxCell>
        <mxCell id="6" value="[3] LLM 翻译&#xa;通过 API 批量翻译，失败片段自愈重试" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;strokeWidth=2;fontSize=13;fontColor=#0f172a;align=left;spacingLeft=12;spacingTop=8;arcSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="670" width="560" height="102" as="geometry"/></mxCell>
        <mxCell id="7" value="[4] 重排与合并&#xa;双语合并 + 每条字幕最多 2 行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;strokeWidth=2;fontSize=13;fontColor=#0f172a;align=left;spacingLeft=12;spacingTop=8;arcSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="800" width="560" height="102" as="geometry"/></mxCell>
